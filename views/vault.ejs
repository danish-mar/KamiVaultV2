<%
  // ─── Vault Apple Branding ──────────────────────────────────────────────────
  const dColors = {
    Land:      'amber',
    Health:    'emerald',
    Municipal: 'indigo',
    Revenue:   'rose',
    Education: 'sky',
  };
  function getDColor(d) { return dColors[d] || 'gray'; }
%>

<style>
    @keyframes vaultAppear { from { opacity: 0; scale: 0.98; filter: blur(4px); } to { opacity: 1; scale: 1; filter: blur(0); } }
    .animate-vault-card { animation: vaultAppear 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; animation-delay: calc(var(--animation-order) * 0.08s); }
    .vault-card { transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); }
    .vault-card:hover { transform: translateY(-8px); box-shadow: 0 30px 60px -15px rgba(0,0,0,0.15); }
    .filter-pill { transition: all 0.2s ease; }
    .filter-pill.active { background: #7c3aed; color: white; border-color: transparent; box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3); }
</style>

<div class="space-y-8 max-w-6xl mx-auto py-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-gray-100 pb-10">
        <div class="space-y-1">
            <h1 class="text-2xl font-bold tracking-tight text-gray-900 leading-tight">Secure Vault</h1>
            <p class="text-[14px] text-gray-500 font-medium tracking-tight">Access your saved documents and digitized records.</p>
        </div>
        <button class="bg-white border border-gray-100 text-[12px] font-bold text-gray-600 px-5 py-2.5 rounded-full hover:bg-gray-50 transition-all flex items-center space-x-2">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
             <span>Export All Data</span>
        </button>
    </div>

    <!-- Toolbar Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex-grow relative max-w-md group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 group-focus-within:text-purple-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" placeholder="Search across naming, ID, or department..." class="w-full pl-11 pr-6 py-3 bg-gray-50/80 border border-transparent rounded-[20px] focus:bg-white focus:border-purple-200 outline-none text-[13px] font-medium transition-all">
        </div>
        <div class="flex items-center space-x-2 bg-gray-50/50 p-1 rounded-[22px] border border-gray-100/50">
            <button class="filter-pill active px-4 py-2 rounded-[16px] text-[10px] font-bold uppercase tracking-widest border border-gray-100">All Files</button>
            <button class="filter-pill px-4 py-2 rounded-[16px] text-[10px] font-bold uppercase tracking-widest text-gray-400 border border-transparent hover:bg-white/60">Completed Only</button>
        </div>
    </div>

    <!-- Vault Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% if (locals.scrolls && scrolls.length > 0) { %>
            <% scrolls.forEach((scroll, index) => { %>
                <% const dColor = getDColor(scroll.department); %>
                <a href="/users/scrolls/<%= scroll._id %>/data" 
                   class="vault-card block bg-white rounded-[36px] p-8 apple-shadow relative group animate-vault-card" 
                   style="--animation-order: <%= index %>;">
                    
                    <div class="flex items-center justify-between mb-8">
                        <div class="h-12 w-12 bg-gradient-to-br from-<%= dColor %>-50 to-<%= dColor %>-100 rounded-[22px] flex items-center justify-center text-<%= dColor %>-600 shadow-sm transition-transform group-hover:scale-105">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                            </svg>
                        </div>
                        <div class="flex items-center space-x-2">
                            <span class="h-1.5 w-1.5 rounded-full <%= scroll.status === 'complete' ? 'bg-green-500' : 'bg-amber-400' %>"></span>
                            <span class="text-[9px] font-extrabold text-gray-400 uppercase tracking-widest opacity-80"><%= scroll.status %></span>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <div class="space-y-0.5">
                            <h3 class="text-lg font-bold text-gray-900 tracking-tight leading-tight"><%= scroll.name %></h3>
                            <p class="text-[10px] font-bold text-<%= dColor %>-500 uppercase tracking-widest"><%= scroll.department %> UNIT</p>
                        </div>

                        <div class="pt-5 grid grid-cols-2 gap-4 border-t border-gray-50/50">
                            <div class="space-y-0.5">
                                <p class="text-[8px] font-extrabold text-gray-300 uppercase tracking-widest">Records Indexed</p>
                                <p class="text-sm font-bold text-gray-900 tracking-tight"><%= scroll.rowCount || 0 %> Items</p>
                            </div>
                            <div class="space-y-0.5">
                                <p class="text-[8px] font-extrabold text-gray-300 uppercase tracking-widest">Confidence Score</p>
                                <p class="text-sm font-bold text-purple-600 tracking-tight">99.8%</p>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Bar -->
                    <div class="mt-8 flex items-center justify-between">
                         <div class="space-y-0.5">
                             <p class="text-[8px] font-extrabold text-gray-300 uppercase tracking-widest">Initialized Date</p>
                             <p class="text-[11px] font-semibold text-gray-500"><%= new Date(scroll.createdAt).toLocaleDateString() %></p>
                         </div>
                         <div class="h-8 w-8 bg-gray-50 rounded-full flex items-center justify-center text-gray-400 group-hover:bg-purple-600 group-hover:text-white transition-all shadow-sm">
                             <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                         </div>
                    </div>
                </a>
            <% }) %>
        <% } else { %>
            <div class="col-span-full py-24 flex flex-col items-center justify-center space-y-6 text-center animate-vault-card" style="opacity: 1">
                 <div class="h-20 w-20 bg-gray-50 rounded-[32px] flex items-center justify-center text-gray-200 border border-gray-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                 </div>
                 <div class="space-y-1">
                    <p class="text-lg font-bold text-gray-800 tracking-tight">Vault is Empty</p>
                    <p class="text-[13px] text-gray-400 font-medium max-w-xs px-4 leading-relaxed">Initialize a digitization campaign to start securing and indexing your documents.</p>
                 </div>
                 <a href="/users/scrolls" class="bg-purple-600 text-white px-8 py-3 rounded-full text-xs font-bold uppercase tracking-widest shadow-lg shadow-purple-100 hover:bg-purple-700 transition-all">Initialize Campaign</a>
            </div>
        <% } %>
    </div>
</div>
