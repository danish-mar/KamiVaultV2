<div class="max-w-6xl mx-auto py-8 space-y-12 animate-slide-up">
    <!-- Dashboard Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 pb-10 border-b border-gray-100">
        <div class="space-y-1">
            <h1 class="text-2xl font-bold tracking-tight text-gray-900 leading-tight">Dashboard</h1>
            <p class="text-[13px] text-gray-500 font-medium tracking-tight">An overview of your digitized documents and collections.</p>
        </div>
        <div class="flex items-center px-6 py-3 bg-white border border-gray-100 rounded-full apple-shadow-lg group transition-all hover:bg-gray-50">
            <span class="text-[10px] font-extrabold text-gray-300 uppercase tracking-[0.2em] mr-4">Authorized</span>
            <div class="flex items-center space-x-3 border-l border-gray-100 pl-4">
                <span class="text-sm font-bold text-gray-900 group-hover:text-purple-600 transition-colors"><%= user.username %></span>
                <div class="h-2 w-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]"></div>
            </div>
        </div>
    </div>
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-[40px] apple-shadow-lg space-y-6 group hover:scale-[1.02] transition-all duration-300 ring-1 ring-gray-100/50">
            <div class="h-12 w-12 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-all duration-500">
                 <!-- Vault Icon -->
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <rect x="3" y="11" width="18" height="10" rx="2" stroke-width="2"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11V7a5 5 0 0110 0v4M12 15v2m0 0v1" />
                 </svg>
            </div>
            <div>
                <p class="text-[9px] font-extrabold text-gray-300 uppercase tracking-[0.2em] mb-1">Active Collections</p>
                <div class="flex items-baseline space-x-1.5">
                    <span class="text-3xl font-bold text-gray-900 tracking-tighter"><%= stats.vaultCount %></span>
                    <span class="text-[11px] font-bold text-purple-400/60 uppercase tracking-widest">Vaults</span>
                </div>
            </div>
        </div>
        <div class="bg-white p-8 rounded-[40px] apple-shadow-lg space-y-6 group hover:scale-[1.02] transition-all duration-300 ring-1 ring-gray-100/50">
            <div class="h-12 w-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all duration-500">
                 <!-- Data Stack Icon -->
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1.5 3 8 3s8-1 8-3V7M4 7c0 2 1.5 3 8 3s8-1 8-3M4 7c0-2 1.5-3 8-3s8 1-8 3m0 5c0 2 1.5 3 8 3s8-1 8-3" />
                 </svg>
            </div>
            <div>
                <p class="text-[9px] font-extrabold text-gray-300 uppercase tracking-[0.2em] mb-1">Total Documents</p>
                <div class="flex items-baseline space-x-1.5">
                    <span class="text-3xl font-bold text-gray-900 tracking-tighter"><%= stats.recordCount %></span>
                    <span class="text-[11px] font-bold text-blue-400/60 uppercase tracking-widest">Files</span>
                </div>
            </div>
        </div>
        <div class="bg-white p-8 rounded-[40px] apple-shadow-lg space-y-6 group hover:scale-[1.02] transition-all duration-300 ring-1 ring-gray-100/50">
            <div class="h-12 w-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-all duration-500">
                 <!-- Integrity Badge Icon -->
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M12 3l9 4v5a9 9 0 01-18 0V7l9-4z" />
                 </svg>
            </div>
            <div>
                <p class="text-[9px] font-extrabold text-gray-300 uppercase tracking-[0.2em] mb-1">Data Accuracy</p>
                <div class="flex items-baseline space-x-1.5">
                    <span class="text-3xl font-bold text-emerald-600 tracking-tighter"><%= stats.integrity %></span>
                    <span class="text-[14px] font-extrabold text-emerald-400 tracking-widest">%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Empty State -->
    <% if (stats.vaultCount === 0) { %>
        <div class="bg-gray-50/50 rounded-[48px] py-32 border border-gray-100 flex flex-col items-center justify-center space-y-8 text-center ring-12 ring-gray-100/50">
            <div class="h-28 w-28 bg-white text-gray-200 rounded-[40px] flex items-center justify-center apple-shadow-lg ring-12 ring-white/50">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div class="space-y-2">
                <h3 class="text-xl font-bold text-gray-800 tracking-tight">Vault is Idle</h3>
                <p class="text-[13px] text-gray-400 font-medium max-w-[280px] leading-relaxed mx-auto">No campaigns detected under this principal. Transition to initialization to begin.</p>
            </div>
            <a href="/users/scrolls" class="bg-purple-600 text-white px-10 py-4 rounded-full text-sm font-bold shadow-xl shadow-purple-200 hover:bg-purple-700 transition-all transform hover:scale-105 active:scale-95">Initialize First Campaign</a>
        </div>
    <% } else { %>
         <div class="bg-purple-50/50 rounded-[48px] p-10 border border-purple-100/50 flex flex-col md:flex-row items-center justify-between group overflow-hidden relative">
             <div class="space-y-4 relative z-10">
                 <div class="space-y-1">
                     <h3 class="text-xl font-bold text-gray-800 tracking-tight">System Operational</h3>
                     <p class="text-[13px] text-gray-500 font-medium max-w-sm">All vaults are synchronized and secured. Records are currently undergoing secondary verification.</p>
                 </div>
                 <div class="flex items-center space-x-4">
                     <div class="flex -space-x-2">
                         <div class="h-6 w-6 rounded-full bg-amber-100 border-2 border-white ring-1 ring-amber-50"></div>
                         <div class="h-6 w-6 rounded-full bg-emerald-100 border-2 border-white ring-1 ring-emerald-50"></div>
                         <div class="h-6 w-6 rounded-full bg-indigo-100 border-2 border-white ring-1 ring-indigo-50"></div>
                     </div>
                     <span class="text-[10px] font-bold text-purple-600 uppercase tracking-widest">Multi-Dept Sync Active</span>
                 </div>
             </div>
             <div class="mt-8 md:mt-0 h-24 w-24 bg-white rounded-3xl flex items-center justify-center apple-shadow ring-8 ring-purple-50 relative z-10 group-hover:rotate-6 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
             </div>
         </div>

         <!-- Recent Activity -->
         <% if (locals.recentDocs && recentDocs.length > 0) { %>
            <div class="space-y-6">
                <div class="flex items-center justify-between px-2">
                    <h3 class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">Recent Activity</h3>
                    <a href="/users/vault" class="text-[10px] font-bold text-purple-600 uppercase tracking-widest hover:underline">Full Audit Log</a>
                </div>
                <div class="bg-white rounded-[40px] apple-shadow-lg p-2 overflow-hidden ring-1 ring-gray-100/50">
                    <div class="divide-y divide-gray-50/50">
                        <% recentDocs.forEach(doc => { %>
                            <% 
                                const dColor = {
                                    Land: 'amber', Health: 'emerald', Municipal: 'indigo', 
                                    Revenue: 'rose', Education: 'sky'
                                }[doc.scroll.department] || 'gray';
                            %>
                            <a href="/users/documents/<%= doc._id %>" class="flex items-center justify-between p-5 hover:bg-gray-50/50 transition-colors group">
                                <div class="flex items-center space-x-4">
                                    <div class="h-10 w-10 bg-<%= dColor %>-50 text-<%= dColor %>-500 rounded-xl flex items-center justify-center transition-transform group-hover:scale-105">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-[12.5px] font-bold text-gray-900 leading-none"><%= doc.name %></p>
                                        <p class="text-[10px] text-gray-300 font-mono mt-1.5"><%= doc.scroll.name %> · <%= new Date(doc.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-6">
                                    <span class="text-[9px] font-extrabold uppercase tracking-widest text-<%= dColor %>-500 bg-<%= dColor %>-50/50 px-2.5 py-1 rounded-lg ring-1 ring-<%= dColor %>-100/50"><%= doc.scroll.department %></span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-300 group-hover:text-purple-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
         <% } %>
    <% } %>
</div>
