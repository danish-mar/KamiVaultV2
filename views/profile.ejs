<div class="max-w-xl mx-auto space-y-12 py-20">
    <div class="flex items-center justify-between border-b border-gray-100 pb-8">
        <div>
            <h2 class="text-3xl font-semibold tracking-tight text-gray-900">User Profile</h2>
            <p class="text-sm text-gray-500 mt-1">Manage your vault settings</p>
        </div>
        <div class="h-16 w-16 bg-purple-100 rounded-full flex items-center justify-center text-purple-600 font-semibold text-xl">
            <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white border border-gray-100 p-6 rounded-2xl apple-shadow">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Account Details</h3>
            <div class="space-y-4">
                <div>
                    <p class="text-xs text-gray-400">Username</p>
                    <p class="text-sm font-medium text-gray-900"><%= user.username %></p>
                </div>
                <div>
                    <p class="text-xs text-gray-400">Email</p>
                    <p class="text-sm font-medium text-gray-900"><%= user.email %></p>
                </div>
            </div>
        </div>
        
        <div class="bg-white border border-gray-100 p-6 rounded-2xl apple-shadow flex flex-col justify-center items-center text-center space-y-4">
            <div class="h-10 w-10 bg-green-50 text-green-500 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-gray-900">Authenticated</h3>
                <p class="text-xs text-gray-500 mt-1">Your JWT token is valid</p>
            </div>
        </div>
    </div>
    
    <div class="flex justify-center pt-8">
        <a href="/auth/login" class="text-sm font-medium text-gray-400 hover:text-red-500 transition-colors">Sign Out</a>
    </div>
</div>
