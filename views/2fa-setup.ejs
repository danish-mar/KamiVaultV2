<div class="max-w-md mx-auto space-y-8 py-10">
    <div class="text-center space-y-2">
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-purple-50 border border-purple-100 mb-2">
            <i class="fas fa-shield-halved text-[10px] text-purple-600"></i>
            <span class="text-[10px] font-bold text-purple-600 uppercase tracking-widest">Enhanced Security</span>
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900">Secure Your Account</h2>
        <p class="text-sm text-gray-500 max-w-xs mx-auto">Scan the QR code with your authenticator app to enable Two-Factor Authentication.</p>
    </div>

    <div class="bg-white border border-gray-100 p-10 rounded-[32px] apple-shadow-lg space-y-8 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 -mr-8 -mt-8 h-32 w-32 bg-purple-50 rounded-full blur-3xl opacity-50"></div>
        
        <div class="flex flex-col items-center space-y-6">
            <!-- QR Code Container -->
            <div class="p-4 bg-white rounded-3xl border-2 border-dashed border-gray-100 shadow-inner group hover:border-purple-200 transition-colors">
                <img src="<%= qrDataUrl %>" alt="2FA QR Code" class="w-48 h-48 rounded-xl">
            </div>

            <div class="text-center space-y-1">
                <p class="text-[10px] font-extrabold text-gray-300 uppercase tracking-[0.2em]">Manual Entry Code</p>
                <code class="text-xs font-mono font-bold text-gray-600 tracking-wider bg-gray-50 px-3 py-1 rounded-lg border border-gray-100"><%= secret %></code>
            </div>
        </div>

        <form action="/auth/2fa-setup" method="POST" class="space-y-6">
            <div class="space-y-3">
                <label for="token" class="block text-[11px] font-extrabold text-gray-400 uppercase tracking-widest text-center">Verify 6-Digit Code</label>
                <input type="text" 
                       id="token" 
                       name="token" 
                       required 
                       maxlength="6" 
                       placeholder="000000" 
                       pattern="[0-9]{6}"
                       class="w-full text-center text-2xl font-black tracking-[0.4em] px-5 py-5 bg-gray-50 border border-transparent rounded-[24px] focus:bg-white focus:border-purple-200 focus:apple-shadow outline-none transition-all placeholder:text-gray-200">
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <p class="text-[11px] font-bold text-rose-500 text-center animate-pulse"><i class="fas fa-triangle-exclamation mr-1"></i> <%= error %></p>
                <% } %>
            </div>

            <button type="submit" class="w-full bg-purple-600 text-white py-5 rounded-[24px] text-sm font-bold shadow-xl shadow-purple-200 hover:bg-purple-700 transition-all flex items-center justify-center space-x-3 group">
                <span>Finalise Setup</span>
                <i class="fas fa-arrow-right text-[10px] group-hover:translate-x-1 transition-transform"></i>
            </button>
        </form>
    </div>

    <div class="text-center text-[11px] text-gray-400 space-y-1">
        <p>Recommended apps: <strong class="text-gray-600">Google Authenticator</strong> or <strong class="text-gray-600">Authy</strong>.</p>
        <p class="opacity-60">You will be required to enter a code every time you sign in.</p>
    </div>
</div>
