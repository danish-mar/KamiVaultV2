<div class="max-w-2xl space-y-12">
    <div class="border-b border-gray-100 pb-8">
        <h1 class="text-3xl font-semibold tracking-tight text-gray-900">Settings</h1>
        <p class="text-sm text-gray-500 mt-1">Personalize your security and profile preferences</p>
    </div>

    <div class="space-y-6">
        <div class="bg-white border border-gray-100 rounded-2xl apple-shadow overflow-hidden">
            <div class="p-6 space-y-4">
                <h3 class="text-sm font-semibold text-gray-900">Account Configuration</h3>
                <div class="space-y-4">
                    <div class="flex items-center justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Username</span>
                        <span class="text-sm font-medium text-gray-900"><%= user.username %></span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Email</span>
                        <span class="text-sm font-medium text-gray-900"><%= user.email %></span>
                    </div>

                    <div class="pt-6 pb-2 space-y-4">
                        <div class="flex items-center justify-between">
                            <div class="space-y-1">
                                <h4 class="text-sm font-semibold text-gray-900">Two-Factor Authentication</h4>
                                <p class="text-[12px] text-gray-400">Add an extra layer of security to your account.</p>
                            </div>
                            <% if (user.twoFactorEnabled) { %>
                                <span class="px-3 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-bold rounded-full border border-emerald-100 uppercase tracking-widest">Active</span>
                            <% } else { %>
                                <span class="px-3 py-1 bg-gray-50 text-gray-400 text-[10px] font-bold rounded-full border border-gray-100 uppercase tracking-widest">Inactive</span>
                            <% } %>
                        </div>
                        
                        <div class="flex justify-start">
                            <% if (!user.twoFactorEnabled) { %>
                                <form action="/auth/2fa/enable" method="POST">
                                    <button type="submit" class="bg-purple-600 text-white px-5 py-2 rounded-xl text-[12px] font-bold shadow-lg shadow-purple-100 hover:bg-purple-700 transition-all flex items-center space-x-2">
                                        <i class="fas fa-shield-plus text-[11px]"></i>
                                        <span>Secure My Account</span>
                                    </button>
                                </form>
                            <% } else { %>
                                <form action="/auth/2fa/disable" method="POST">
                                    <button type="submit" class="text-sm font-medium text-purple-600 hover:underline">Deactivate 2FA</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-2xl apple-shadow overflow-hidden">
            <div class="p-6 space-y-4">
                <h3 class="text-sm font-semibold text-gray-900 text-red-500">Danger Zone</h3>
                <button class="text-sm font-medium text-red-500 hover:text-red-600 transition-colors">Delete Account</button>
            </div>
        </div>
    </div>
</div>
