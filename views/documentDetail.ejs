    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 border-b border-gray-100 pb-10">
        <div class="flex items-center space-x-6">
             <a href="/users/scrolls/<%= doc.scroll._id %>" class="h-12 w-12 bg-white border border-gray-100 rounded-full flex items-center justify-center hover:apple-shadow transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 group-hover:text-purple-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
             </a>
             <div class="space-y-1.5">
                <div class="flex items-center space-x-2.5">
                    <span class="text-[9px] font-extrabold text-purple-500 uppercase tracking-widest bg-purple-50 px-2.5 py-1 rounded-lg ring-1 ring-purple-100/50"><%= doc.scroll.department %></span>
                    <span class="text-[9px] font-bold text-gray-300 font-mono uppercase tracking-widest">KMA-<%= (doc._id || '').toString().slice(-6).toUpperCase() %></span>
                </div>
                <h1 class="text-2xl font-bold tracking-tight text-gray-900 leading-tight"><%= doc.name %></h1>
             </div>
        </div>
         <div class="flex items-center space-x-8">
             <div class="text-right">
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1.5">Accuracy Rating</p>
                <div class="flex items-baseline justify-end space-x-1">
                    <span class="text-2xl font-bold text-purple-600 tracking-tighter"><%= (doc.confidenceScore || 0).toFixed(1) %></span>
                    <span class="text-[11px] font-bold text-purple-400">%</span>
                </div>
             </div>
             <div class="h-10 w-px bg-gray-100"></div>
             <form action="/users/documents/<%= doc._id %>/flag" method="POST" data-loader>
                <button type="submit" class="px-8 py-3 bg-white border border-gray-100 <%= doc.flaggedForReview ? 'text-amber-500 border-amber-100 bg-amber-50/30' : 'text-rose-500 hover:bg-rose-50 hover:border-rose-100' %> rounded-full text-[11px] font-bold uppercase tracking-widest transition-all apple-shadow active:scale-95 flex items-center space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="<%= doc.flaggedForReview ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" /></svg>
                    <span><%= doc.flaggedForReview ? 'Unflag Record' : 'Flag for Review' %></span>
                </button>
             </form>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Structural Data -->
        <div class="space-y-8">
            <div class="bg-white border border-gray-50 rounded-[40px] p-10 apple-shadow-lg ring-1 ring-gray-100/30">
                <div class="flex items-center justify-between mb-10">
                    <h3 class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">Extracted Nucleus</h3>
                    <div class="flex items-center space-x-2 px-2.5 py-1 bg-green-50 text-green-600 rounded-lg">
                        <span class="relative flex h-1.5 w-1.5">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                        </span>
                        <span class="text-[9px] font-bold uppercase tracking-widest">Verified</span>
                    </div>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">
                    <% Object.keys(doc.extractedData || {}).forEach(key => { %>
                        <div class="space-y-1.5">
                            <label class="block text-[9px] font-extrabold text-gray-300 uppercase tracking-[0.15em] leading-none"><%= key.replace(/_/g, ' ') %></label>
                            <p class="text-[13px] font-bold text-gray-800 leading-relaxed"><%= doc.extractedData[key] || '-' %></p>
                        </div>
                    <% }) %>
                </div>

                <% if (doc.pgRowId) { %>
                    <div class="mt-12 bg-gray-50/50 p-6 rounded-[24px] border border-gray-100 flex items-center justify-between group">
                         <div>
                            <p class="text-[9px] text-gray-400 font-extrabold uppercase tracking-widest leading-none mb-1.5">Relational Mapping</p>
                            <div class="flex items-center space-x-2">
                                <p class="text-[11px] font-mono text-gray-600 font-bold bg-white px-2 py-0.5 rounded-md border border-gray-100 shadow-sm">Row_UID::<%= doc.pgRowId %></p>
                            </div>
                         </div>
                         <div class="h-10 w-10 bg-white text-purple-600 rounded-full flex items-center justify-center apple-shadow border border-gray-50 group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                            </svg>
                         </div>
                    </div>
                <% } %>
            </div>

            <!-- Analysis Metadata -->
            <div class="bg-white/50 border border-gray-50/50 rounded-[32px] p-8 apple-shadow flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <div class="h-10 w-10 bg-purple-600 rounded-xl flex items-center justify-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-gray-800 leading-none">Gemini-Pro Engine</p>
                        <p class="text-[9px] text-gray-400 mt-1">Multi-modal Extraction v2.4</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-[10px] font-bold text-purple-600 uppercase tracking-widest">Process Active</p>
                    <p class="text-[9px] text-gray-300 font-mono mt-0.5"><%= new Date(doc.createdAt).toLocaleDateString() %></p>
                </div>
            </div>
        </div>

        <div class="space-y-6">
             <div class="bg-gray-100/50 border-4 border-white rounded-[48px] p-1.5 overflow-hidden min-h-[700px] flex flex-col items-center justify-center relative apple-shadow-lg ring-1 ring-gray-100">
                 <% if (doc.name.toLowerCase().endsWith('.pdf')) { %>
                    <div class="absolute inset-x-3 top-3 bottom-24 bg-white/40 backdrop-blur-sm rounded-[36px] overflow-hidden border border-white/50">
                        <iframe src="<%= viewUrl %>" class="w-full h-full border-0 select-none" style="pointer-events: auto;"></iframe>
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-white/90 z-10 pointer-events-none"></div>
                 <% } else { %>
                    <div class="absolute inset-x-3 top-3 bottom-24 bg-white/40 backdrop-blur-sm rounded-[36px] overflow-hidden border border-white/50 flex items-center justify-center">
                        <img src="<%= viewUrl %>" class="max-w-full max-h-full object-contain shadow-2xl rounded-xl">
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-white/90 z-10 pointer-events-none"></div>
                 <% } %>
                 
                 <div class="text-center space-y-4 text-gray-400 relative z-20 mt-[500px]">
                    <p class="text-[15px] font-bold text-gray-800 tracking-tight">Source Asset Inspection</p>
                    <p class="text-[11px] font-medium max-w-[240px] mx-auto leading-relaxed">Direct visual link to the physical artifact stored in your local S3 cloud.</p>
                    <p class="text-[10px] font-mono bg-white/60 px-4 py-1.5 rounded-full inline-block text-gray-400 border border-white/80 shadow-sm"><%= doc.s3Url %></p>
                 </div>

                 <div class="absolute bottom-10 inset-x-10 z-30">
                     <a href="<%= viewUrl %>" download="<%= doc.name %>" class="w-full bg-white text-gray-800 py-4 rounded-[20px] text-[12px] font-bold uppercase tracking-widest apple-shadow hover:bg-gray-50 transition-all flex items-center justify-center space-x-3 group">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple-600 group-hover:scale-125 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                        <span>Download Production Asset</span>
                     </a>
                 </div>
             </div>
        </div>
    </div>
</div>
