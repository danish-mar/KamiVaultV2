<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - KamiVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { 
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: #FBFBFD;
            letter-spacing: -0.011em;
        }
        .apple-shadow { 
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.08); 
        }
        .apple-shadow-lg {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.04), 0 8px 10px -6px rgba(0, 0, 0, 0.04);
        }
        .sidebar-transition { transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); }
        .glass-sidebar {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(30px) saturate(180%);
            -webkit-backdrop-filter: blur(30px) saturate(180%);
        }
        @media (max-width: 768px) {
            .sidebar-closed { transform: translateX(-100%); }
        }
        /* Custom scrollbar for a clean look */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #E5E5E7; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #D1D1D6; }
    </style>
</head>
<body class="text-gray-900 h-screen overflow-hidden flex selection:bg-purple-100 selection:text-purple-900">
    <% if (typeof user !== 'undefined' && user) { %>
        <!-- Sidebar -->
        <aside id="sidebar" class="w-56 border-r border-gray-100 flex flex-col h-full fixed md:relative z-40 glass-sidebar sidebar-transition flex-shrink-0 shadow-[1px_0_0_0_rgba(0,0,0,0.02)]">
            <div class="px-6 py-6 flex items-center justify-between">
                <a href="/users/dashboard" class="flex items-center space-x-3 group">
                    <div class="h-8 w-8 bg-purple-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-purple-200 group-hover:rotate-[15deg] transition-all duration-500">
                        <!-- Kami Sushi Maki Logo -->
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <circle cx="12" cy="12" r="9" stroke-width="2.5"/>
                            <circle cx="12" cy="12" r="3.5" stroke-width="2" fill="currentColor"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 3v2m0 14v2M3 12h2m14 0h2" />
                        </svg>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-[13px] font-extrabold tracking-tight text-gray-900 leading-none">KamiVault</span>
                        <span class="text-[8px] font-bold text-purple-500 uppercase tracking-[0.2em] mt-1">Kami Sushi Pro</span>
                    </div>
                </a>
                <button onclick="toggleSidebar()" class="md:hidden text-gray-400 hover:text-gray-900 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <nav class="flex-grow px-3 space-y-0.5">
                <a href="/users/dashboard" class="flex items-center space-x-3 px-3.5 py-2 rounded-xl text-[12.5px] font-medium transition-all <%= title === 'Dashboard' ? 'bg-purple-50 text-purple-600 shadow-sm' : 'text-gray-500 hover:bg-gray-50/80 hover:text-gray-900' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                    </svg>
                    <span>Dashboard</span>
                </a>
                <a href="/users/scrolls" class="flex items-center space-x-3 px-3.5 py-2 rounded-xl text-[12.5px] font-medium transition-all <%= title === 'Scrolls' ? 'bg-purple-50 text-purple-600 shadow-sm' : 'text-gray-500 hover:bg-gray-50/80 hover:text-gray-900' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <span>Scrolls</span>
                </a>
                <a href="/users/vault" class="flex items-center space-x-3 px-3.5 py-2 rounded-xl text-[12.5px] font-medium transition-all <%= title === 'Vault' ? 'bg-purple-50 text-purple-600 shadow-sm' : 'text-gray-500 hover:bg-gray-50/80 hover:text-gray-900' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <span>Vault</span>
                </a>
                <a href="/users/profile" class="flex items-center space-x-3 px-3.5 py-2 rounded-xl text-[12.5px] font-medium transition-all <%= title === 'Profile' ? 'bg-purple-50 text-purple-600 shadow-sm' : 'text-gray-500 hover:bg-gray-50/80 hover:text-gray-900' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <span>Profile</span>
                </a>
                <div class="h-px bg-gray-100 mx-3 my-2"></div>
                <a href="/users/how-it-works" class="flex items-center space-x-3 px-3.5 py-2 rounded-xl text-[12.5px] font-medium transition-all <%= title === 'How It Works' ? 'bg-purple-50 text-purple-600 shadow-sm' : 'text-gray-500 hover:bg-gray-50/80 hover:text-gray-900' %>">
                    <i class="fas fa-circle-question h-4 w-4 text-[14px] flex items-center justify-center"></i>
                    <span>How it Works</span>
                </a>
            </nav>

            <div class="px-2 py-4">
                <div class="bg-white/60 p-2.5 rounded-xl ring-1 ring-gray-100/50 shadow-sm">
                    <div class="flex items-center space-x-2.5 mb-3">
                        <div class="h-7 w-7 bg-purple-600 rounded-lg flex items-center justify-center text-white font-bold text-[10px]">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                        <div class="flex-grow min-w-0">
                            <p class="text-[11px] font-bold text-gray-900 truncate leading-none"><%= user.username %></p>
                            <p class="text-[9px] text-gray-400 truncate mt-1"><%= user.email %></p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-1.5 px-0.5">
                        <a href="/users/profile" class="flex-grow bg-white border border-gray-100 text-[10px] font-bold text-gray-500 py-1.5 px-2 rounded-lg text-center hover:bg-gray-50 transition-colors">Settings</a>
                        <a href="/auth/login" class="bg-rose-50 text-rose-500 p-1.5 rounded-lg hover:bg-rose-100 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <div class="flex-grow flex flex-col min-w-0 h-full overflow-y-auto">
            <header class="h-12 border-b border-gray-50 flex items-center px-8 bg-white/70 backdrop-blur-md sticky top-0 z-30 justify-between">
                <div class="flex items-center">
                    <button onclick="toggleSidebar()" class="mr-4 text-gray-400 md:hidden hover:text-gray-900 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7" />
                        </svg>
                    </button>
                    <h2 class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] leading-none"><%= title %></h2>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="h-1.5 w-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.4)]"></div>
                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Network Active</span>
                </div>
            </header>
            <main class="flex-grow p-8">
                <%- body %>
            </main>
        </div>

        <script>
            function toggleSidebar() {
                const sidebar = document.getElementById('sidebar');
                sidebar.classList.toggle('sidebar-closed');
            }
        </script>
    <% } else { %>
        <!-- Guest Layout (Login / Register / Home) -->
        <div class="flex-grow flex flex-col min-h-screen overflow-y-auto bg-[#FBFBFD]">
            <header class="sticky top-0 z-50 border-b border-gray-100/80 bg-white/70 backdrop-blur-xl py-3.5 px-8 md:px-16 flex justify-between items-center">
                <a href="/" class="flex items-center space-x-2.5 group">
                    <div class="h-6 w-6 bg-purple-600 rounded-lg flex items-center justify-center text-white shadow-sm shadow-purple-200 group-hover:scale-105 transition-transform">
                        <i class="fas fa-bolt text-[10px]"></i>
                    </div>
                    <span class="text-[15px] font-bold tracking-tight text-gray-900">KamiVault</span>
                </a>
                <nav class="flex items-center space-x-1 text-[13px] font-medium">
                    <a href="/" class="px-3 py-1.5 text-gray-500 hover:text-gray-900 transition-colors rounded-lg hover:bg-gray-50">Home</a>
                    <a href="/auth/login" class="px-3 py-1.5 text-gray-500 hover:text-gray-900 transition-colors rounded-lg hover:bg-gray-50">Sign In</a>
                    <a href="/auth/register" class="ml-2 px-4 py-1.5 bg-gray-900 text-white text-[12px] font-semibold rounded-xl hover:bg-black transition-colors">Get Started</a>
                </nav>
            </header>

            <main class="flex-grow">
                <%- body %>
            </main>

            <footer class="border-t border-gray-100 py-8 px-8 md:px-16 flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center space-x-2">
                    <div class="h-5 w-5 bg-purple-600 rounded-md flex items-center justify-center text-white">
                        <i class="fas fa-bolt text-[8px]"></i>
                    </div>
                    <span class="text-[11px] font-bold text-gray-400">KamiVault</span>
                </div>
                <p class="text-[11px] text-gray-300 font-medium">© 2026 KamiVault. Secure document intelligence.</p>
                <div class="flex items-center space-x-4 text-[11px] font-medium text-gray-400">
                    <a href="/auth/login" class="hover:text-gray-700 transition-colors">Sign in</a>
                    <a href="/auth/register" class="hover:text-gray-700 transition-colors">Register</a>
                </div>
            </footer>
        </div>
    <% } %>

    <!-- Global Loading Overlay -->
    <div id="loadingOverlay" class="fixed inset-0 bg-white/60 backdrop-blur-md z-[100] hidden flex flex-col items-center justify-center space-y-6">
        <style>
            @keyframes manageAppear {
                from { opacity: 0; transform: translateY(20px) scale(0.98); }
                to { opacity: 1; transform: translateY(0) scale(1); }
            }
            .animate-manage { animation: manageAppear 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        </style>
        <div class="relative animate-manage">
            <div class="h-20 w-20 border-4 border-purple-50 rounded-full animate-pulse shadow-xl shadow-purple-100/50"></div>
            <div class="h-20 w-20 border-t-4 border-purple-600 rounded-full animate-spin absolute inset-0"></div>
        </div>
        <div class="text-center space-y-1.5 animate-manage">
            <p class="text-lg font-bold text-gray-900 tracking-tight">Processing Assets</p>
            <p class="text-xs text-gray-400 font-medium">KamiVault AI is digitizing your records...</p>
        </div>
    </div>

    <script>
        function showLoader() {
            const loader = document.getElementById('loadingOverlay');
            if (loader) loader.classList.remove('hidden');
        }
        
        // Auto-show loader for forms with data-loader attribute
        document.addEventListener('submit', (e) => {
            if (e.target.hasAttribute('data-loader') || e.target.closest('[data-loader]')) {
                showLoader();
            }
        });
    </script>
</body>
</html>
